#!/usr/bin/env python3
"""
dual-speed

Dual-path transfer helper for NAS workflows.

Public paths remain a single logical mount such as /mnt/nas.
Internal accelerated paths are hidden under a private mount root.
"""

from __future__ import annotations

import argparse
import concurrent.futures
import dataclasses
import hashlib
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path
from typing import Iterable


DEFAULT_CONFIG = {
    "logical_root": "/your-public-nas-mount-here",
    "mount_root": "/mnt/.dual-speed",
    "export_path": "/your-nas-export-here",
    "nfs_version": "3",
    "paths": [
        {"name": "a", "nas_ip": "your-nas-ip-a", "iface": "your-nic-a", "src_ip": "your-client-ip-a"},
        {"name": "b", "nas_ip": "your-nas-ip-b", "iface": "your-nic-b", "src_ip": "your-client-ip-b"},
    ],
}


@dataclasses.dataclass(frozen=True)
class PathSpec:
    name: str
    nas_ip: str
    iface: str
    src_ip: str
    mount: Path


@dataclasses.dataclass(frozen=True)
class FileItem:
    src: Path
    rel: Path
    size: int


def run(cmd: list[str], *, check: bool = True, quiet: bool = False) -> subprocess.CompletedProcess:
    if not quiet:
        print("+ " + " ".join(cmd), flush=True)
    return subprocess.run(cmd, text=True, check=check)


def capture(cmd: list[str], *, check: bool = True) -> str:
    return subprocess.check_output(cmd, text=True, stderr=subprocess.STDOUT).strip()


def require_root(action: str) -> None:
    if os.geteuid() != 0:
        raise SystemExit(f"{action} needs sudo. Re-run with: sudo {' '.join(sys.argv)}")


def load_config(args: argparse.Namespace) -> dict:
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))
    if args.config:
        data = json.loads(Path(args.config).read_text())
        cfg.update(data)
    return cfg


def path_specs(cfg: dict) -> list[PathSpec]:
    root = Path(cfg["mount_root"])
    specs = []
    for p in cfg["paths"]:
        specs.append(
            PathSpec(
                name=p["name"],
                nas_ip=p["nas_ip"],
                iface=p["iface"],
                src_ip=p["src_ip"],
                mount=root / f"via_{p['nas_ip']}",
            )
        )
    if len(specs) < 2:
        raise SystemExit("Need at least two path specs")
    return specs


def logical_root(cfg: dict) -> Path:
    return Path(cfg["logical_root"]).resolve()


def to_internal(logical: Path, spec: PathSpec, cfg: dict) -> Path:
    root = logical_root(cfg)
    logical_abs = logical.resolve() if logical.exists() else Path(os.path.abspath(logical))
    try:
        rel = logical_abs.relative_to(root)
    except ValueError:
        raise SystemExit(f"NAS path must be under {root}: {logical}")
    return spec.mount / rel


def print_status(cfg: dict) -> None:
    specs = path_specs(cfg)
    print(f"logical_root: {cfg['logical_root']}")
    print(f"mount_root:   {cfg['mount_root']}")
    print(f"export_path:  {cfg['export_path']}")
    print(f"nfs_version:  {cfg['nfs_version']}")
    for s in specs:
        print(f"path {s.name}: {s.src_ip}/{s.iface} to {s.nas_ip} to {s.mount}")
    print()
    for s in specs:
        for cmd in (
            ["ip", "-br", "addr", "show", "dev", s.iface],
            ["ip", "route", "get", s.nas_ip],
        ):
            try:
                print(capture(cmd))
            except subprocess.CalledProcessError as exc:
                print(exc.output.strip())
    print()
    run(["findmnt", "-R", cfg["mount_root"]], check=False)


def prepare(cfg: dict, *, remount: bool) -> None:
    require_root("prepare")
    specs = path_specs(cfg)
    mount_root = Path(cfg["mount_root"])
    export_path = cfg["export_path"]
    nfs_version = str(cfg.get("nfs_version", "3"))

    for s in specs:
        run(["ip", "route", "replace", f"{s.nas_ip}/32", "dev", s.iface, "src", s.src_ip])
    run(["ip", "route", "flush", "cache"], check=False)

    mount_root.mkdir(parents=True, exist_ok=True)
    for s in specs:
        s.mount.mkdir(parents=True, exist_ok=True)
        if remount and is_mountpoint(s.mount):
            run(["umount", str(s.mount)])
        if is_mountpoint(s.mount):
            continue
        if nfs_version == "3":
            opts = "vers=3,rsize=1048576,wsize=1048576,proto=tcp,rw,hard,intr,timeo=50,retrans=3,nosharecache,_netdev"
            run(["mount", "-t", "nfs", "-o", opts, f"{s.nas_ip}:{export_path}", str(s.mount)])
        else:
            opts = f"vers={nfs_version},rsize=1048576,wsize=1048576,proto=tcp,rw,acl,hard,intr,timeo=50,retrans=3,nconnect=4,nosharecache,clientaddr={s.src_ip},_netdev"
            run(["mount", "-t", "nfs4", "-o", opts, f"{s.nas_ip}:{export_path}", str(s.mount)])


def is_mountpoint(path: Path) -> bool:
    return subprocess.run(["mountpoint", "-q", str(path)]).returncode == 0


def collect_files(src: Path) -> tuple[Path, list[FileItem]]:
    if src.is_file():
        return src.parent, [FileItem(src=src, rel=Path(src.name), size=src.stat().st_size)]
    if not src.is_dir():
        raise SystemExit(f"Source does not exist: {src}")
    items = []
    for p in sorted(src.rglob("*")):
        if p.is_file():
            items.append(FileItem(src=p, rel=p.relative_to(src), size=p.stat().st_size))
    return src, items


def collect_nas_files(src: Path, cfg: dict) -> tuple[Path, list[FileItem]]:
    specs = path_specs(cfg)
    internal = to_internal(src, specs[0], cfg)
    if internal.is_file():
        return src.parent, [FileItem(src=internal, rel=Path(src.name), size=internal.stat().st_size)]
    if not internal.is_dir():
        raise SystemExit(f"NAS source does not exist: {src}")
    items = []
    for p in sorted(internal.rglob("*")):
        if p.is_file():
            rel = p.relative_to(internal)
            items.append(FileItem(src=p, rel=rel, size=p.stat().st_size))
    return src, items


def assign(items: list[FileItem], specs: list[PathSpec]) -> dict[str, list[FileItem]]:
    loads = {s.name: 0 for s in specs}
    out = {s.name: [] for s in specs}
    for item in sorted(items, key=lambda x: x.size, reverse=True):
        name = min(loads, key=loads.get)
        out[name].append(item)
        loads[name] += item.size
    return out


def file_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def same_size(src: Path, dst: Path) -> bool:
    return dst.exists() and src.stat().st_size == dst.stat().st_size


def decide_strategy(args: argparse.Namespace, items: list[FileItem]) -> str:
    if args.strategy != "auto":
        return args.strategy
    total = sum(i.size for i in items)
    if len(items) < 2:
        return "single"
    min_bytes = int(args.min_dual_size_mb * 1_000_000)
    if total >= min_bytes or len(items) >= args.min_dual_files:
        return "dual"
    return "single"


def print_pack_advice(items: list[FileItem]) -> None:
    total = sum(i.size for i in items)
    count = len(items)
    avg = total / count if count else 0
    if count >= 10000 or (count >= 1000 and avg <= 1_000_000):
        print(
            "small-file advisory: this transfer has many small files. "
            "Packing can help only if the NAS can extract locally via SSH/API. "
            "Without NAS-side extraction, keep file-level transfer; extracting over NFS usually wastes network I/O."
        )


def copy_one(src: Path, dst: Path, *, resume: bool, verify: str, chown: bool) -> dict:
    t0 = time.monotonic()
    dst.parent.mkdir(parents=True, exist_ok=True)
    skipped = False
    if resume and same_size(src, dst):
        skipped = True
    else:
        tmp = dst.with_name(dst.name + ".part")
        if tmp.exists() and not resume:
            tmp.unlink()
        shutil.copyfile(src, tmp)
        os.replace(tmp, dst)
    if verify == "size" and not same_size(src, dst):
        raise RuntimeError(f"size mismatch: {src} to {dst}")
    if verify == "sha256" and file_sha256(src) != file_sha256(dst):
        raise RuntimeError(f"sha256 mismatch: {src} to {dst}")
    if chown:
        uid = int(os.environ.get("SUDO_UID", "0"))
        gid = int(os.environ.get("SUDO_GID", "0"))
        if uid:
            try:
                os.chown(dst, uid, gid)
            except PermissionError:
                pass
    elapsed = max(time.monotonic() - t0, 0.000001)
    return {"bytes": src.stat().st_size, "elapsed": elapsed, "skipped": skipped}


def net_bytes(specs: Iterable[PathSpec]) -> dict[str, dict[str, int]]:
    out = {}
    for s in specs:
        base = Path("/sys/class/net") / s.iface / "statistics"
        out[s.name] = {
            "rx": int((base / "rx_bytes").read_text()),
            "tx": int((base / "tx_bytes").read_text()),
        }
    return out


def print_net_delta(before: dict, after: dict) -> None:
    for name in sorted(before):
        rx = (after[name]["rx"] - before[name]["rx"]) / 1_000_000
        tx = (after[name]["tx"] - before[name]["tx"]) / 1_000_000
        print(f"path {name} net delta: rx={rx:.1f} MB tx={tx:.1f} MB")


def transfer_upload(args: argparse.Namespace, cfg: dict) -> None:
    specs = path_specs(cfg)
    src_base, items = collect_files(Path(args.source))
    if not items:
        print("No files to upload")
        return
    dest_logical = Path(args.dest)
    if not str(dest_logical).startswith(str(logical_root(cfg))):
        raise SystemExit(f"Destination must be under {logical_root(cfg)}")

    strategy = decide_strategy(args, items)
    print_pack_advice(items)
    plan = assign(items, specs)
    if args.dry_run:
        print(f"strategy: {strategy}")
        print_plan("upload", items, plan, specs, dest_logical)
        return

    if strategy == "single":
        print("strategy: single")
        dest_root = dest_logical
        run_single_transfer(items, lambda item: dest_root / item.rel, args, label="upload")
        return

    print("strategy: dual")
    if args.prepare:
        prepare(cfg, remount=args.remount)
    run_transfer(plan, specs, lambda s, item: s.mount / dest_logical.resolve().relative_to(logical_root(cfg)) / item.rel, args)


def transfer_download(args: argparse.Namespace, cfg: dict) -> None:
    specs = path_specs(cfg)
    src_logical = Path(args.source)
    src_base, single_items = collect_files(src_logical)
    items = single_items
    if not items:
        print("No files to download")
        return
    dest = Path(args.dest)
    strategy = decide_strategy(args, items)
    if strategy == "dual":
        if args.prepare:
            prepare(cfg, remount=args.remount)
        src_base, items = collect_nas_files(src_logical, cfg)
    plan = assign(items, specs)
    if args.dry_run:
        print(f"strategy: {strategy}")
        print_plan("download", items, plan, specs, dest)
        return

    def dest_for(spec: PathSpec, item: FileItem) -> Path:
        return dest / item.rel if len(items) > 1 or src_logical.is_dir() else dest

    if strategy == "single":
        print("strategy: single")
        run_single_transfer(items, lambda item: dest / item.rel if len(items) > 1 or src_logical.is_dir() else dest, args, label="download")
        return

    # Re-map each source path to the assigned internal mount so downloads split by NAS IP.
    print("strategy: dual")
    root_a = specs[0].mount
    if (root_a / src_logical.resolve().relative_to(logical_root(cfg))).is_file():
        rel_root = src_logical.parent.resolve().relative_to(logical_root(cfg))
    else:
        rel_root = src_logical.resolve().relative_to(logical_root(cfg))
    remapped = {}
    for spec in specs:
        remapped[spec.name] = [
            FileItem(src=spec.mount / rel_root / item.rel, rel=item.rel, size=item.size)
            for item in plan[spec.name]
        ]
    run_transfer(remapped, specs, dest_for, args)


def run_single_transfer(items: list[FileItem], dest_for, args: argparse.Namespace, *, label: str) -> None:
    total_bytes = sum(item.size for item in items)
    total_files = len(items)
    print(f"{label} single start: {total_files} files, {total_bytes / 1_000_000:.1f} MB")
    t0 = time.monotonic()
    copied = 0
    skipped = 0
    for item in items:
        result = copy_one(
            item.src,
            dest_for(item),
            resume=args.resume,
            verify=args.verify,
            chown=getattr(args, "chown", False),
        )
        copied += 1
        skipped += 1 if result["skipped"] else 0
        print(f"[{copied}/{total_files}] single {'skip' if result['skipped'] else 'ok'} {item.rel}")
    elapsed = max(time.monotonic() - t0, 0.000001)
    print(f"{label} single done: {total_bytes / 1_000_000:.1f} MB in {elapsed:.2f}s = {total_bytes / 1_000_000 / elapsed:.1f} MB/s, skipped={skipped}")


def print_plan(mode: str, items: list[FileItem], plan: dict[str, list[FileItem]], specs: list[PathSpec], dest: Path) -> None:
    total = sum(i.size for i in items)
    print(f"{mode} plan: {len(items)} files, {total / 1_000_000:.1f} MB to {dest}")
    for s in specs:
        size = sum(i.size for i in plan[s.name])
        print(f"  path {s.name} {s.src_ip}/{s.iface} to {s.nas_ip}: {len(plan[s.name])} files, {size / 1_000_000:.1f} MB")


def run_transfer(plan: dict[str, list[FileItem]], specs: list[PathSpec], dest_for, args: argparse.Namespace) -> None:
    total_bytes = sum(item.size for items in plan.values() for item in items)
    total_files = sum(len(items) for items in plan.values())
    print(f"transfer start: {total_files} files, {total_bytes / 1_000_000:.1f} MB")
    before = net_bytes(specs)
    t0 = time.monotonic()
    failures = []
    copied = 0
    skipped = 0
    bytes_done = 0
    by_name = {s.name: s for s in specs}

    def worker(spec_name: str, item: FileItem) -> tuple[str, FileItem, dict]:
        spec = by_name[spec_name]
        return spec_name, item, copy_one(
            item.src,
            dest_for(spec, item),
            resume=args.resume,
            verify=args.verify,
            chown=getattr(args, "chown", False),
        )

    with concurrent.futures.ThreadPoolExecutor(max_workers=len(specs)) as pool:
        futures = []
        for spec in specs:
            for item in plan[spec.name]:
                futures.append(pool.submit(worker, spec.name, item))
        for fut in concurrent.futures.as_completed(futures):
            try:
                spec_name, item, result = fut.result()
                copied += 1
                skipped += 1 if result["skipped"] else 0
                bytes_done += result["bytes"]
                print(f"[{copied}/{total_files}] {spec_name} {'skip' if result['skipped'] else 'ok'} {item.rel}")
            except Exception as exc:
                failures.append(str(exc))
                print(f"ERROR: {exc}", file=sys.stderr)

    elapsed = max(time.monotonic() - t0, 0.000001)
    after = net_bytes(specs)
    print(f"transfer done: {bytes_done / 1_000_000:.1f} MB in {elapsed:.2f}s = {bytes_done / 1_000_000 / elapsed:.1f} MB/s, skipped={skipped}")
    print_net_delta(before, after)
    if failures:
        raise SystemExit(f"{len(failures)} transfer failure(s)")


def speedtest(args: argparse.Namespace, cfg: dict) -> None:
    prepare(cfg, remount=True)
    specs = path_specs(cfg)
    if len(specs) < 2:
        raise SystemExit("speedtest needs at least two path specs")
    size_mb = int(args.size_mb)
    bs_mb = 16
    count = max(size_mb // bs_mb, 1)
    run_id = f".dual_speed_speedtest_{int(time.time())}_{os.getpid()}"
    paths = [(spec, spec.mount / run_id / f"path_{spec.name}.bin") for spec in specs]
    for _, p in paths:
        p.parent.mkdir(parents=True, exist_ok=True)
    before = net_bytes(specs)
    t0 = time.monotonic()
    try:
        with concurrent.futures.ThreadPoolExecutor(max_workers=len(paths)) as pool:
            futs = [
                pool.submit(run, ["dd", "if=/dev/zero", f"of={str(p)}", f"bs={bs_mb}M", f"count={count}", "conv=fdatasync", "status=none"])
                for _, p in paths
            ]
            for fut in concurrent.futures.as_completed(futs):
                fut.result()
        elapsed = max(time.monotonic() - t0, 0.000001)
        total_mb = size_mb * len(paths)
        print(f"upload speedtest: {total_mb} MB in {elapsed:.2f}s = {total_mb / elapsed:.1f} MB/s")
        print_net_delta(before, net_bytes(specs))

        before = net_bytes(specs)
        t1 = time.monotonic()
        with concurrent.futures.ThreadPoolExecutor(max_workers=len(paths)) as pool:
            futs = [
                pool.submit(run, ["dd", f"if={str(p)}", "of=/dev/null", f"bs={bs_mb}M", "iflag=direct", "status=none"])
                for _, p in paths
            ]
            for fut in concurrent.futures.as_completed(futs):
                fut.result()
        elapsed = max(time.monotonic() - t1, 0.000001)
        print(f"download speedtest: {total_mb} MB in {elapsed:.2f}s = {total_mb / elapsed:.1f} MB/s")
        print_net_delta(before, net_bytes(specs))
    finally:
        for _, p in paths:
            try:
                p.unlink()
            except FileNotFoundError:
                pass
            try:
                p.parent.rmdir()
            except OSError:
                pass


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="dual-speed accelerated transfer for NAS workflows")
    p.add_argument("--config", help="Optional JSON config override")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("status")

    pp = sub.add_parser("prepare")
    pp.add_argument("--remount", action="store_true", help="Force remount hidden paths")

    sp = sub.add_parser("speedtest")
    sp.add_argument("--size-mb", type=int, default=1024)

    for name in ("upload", "download"):
        cp = sub.add_parser(name)
        cp.add_argument("source")
        cp.add_argument("dest")
        cp.add_argument("--no-prepare", dest="prepare", action="store_false", help="Do not set routes/mounts first")
        cp.add_argument("--remount", action="store_true", help="Force remount hidden paths before transfer")
        cp.add_argument("--resume", action="store_true", default=True, help="Skip existing same-size files")
        cp.add_argument("--no-resume", dest="resume", action="store_false")
        cp.add_argument("--verify", choices=("none", "size", "sha256"), default="size")
        cp.add_argument("--dry-run", action="store_true")
        cp.add_argument("--strategy", choices=("auto", "dual", "single"), default="auto",
                        help="auto selects single for small transfers and dual for larger transfers")
        cp.add_argument("--min-dual-size-mb", type=float, default=256.0,
                        help="auto uses dual for multi-file transfers when total size is at least this many MB")
        cp.add_argument("--min-dual-files", type=int, default=16,
                        help="auto uses dual when file count is at least this value")
        if name == "upload":
            cp.add_argument("--chown", action="store_true", default=True, help="Chown uploaded files to sudo caller when possible")
            cp.add_argument("--no-chown", dest="chown", action="store_false")
    return p


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    cfg = load_config(args)
    if args.cmd == "status":
        print_status(cfg)
    elif args.cmd == "prepare":
        prepare(cfg, remount=args.remount)
        print_status(cfg)
    elif args.cmd == "speedtest":
        speedtest(args, cfg)
    elif args.cmd == "upload":
        transfer_upload(args, cfg)
    elif args.cmd == "download":
        transfer_download(args, cfg)
    else:
        parser.error("unknown command")


if __name__ == "__main__":
    main()
